# Copy this file to .streamlit/secrets.toml and fill in your API keys.
# NEVER commit secrets.toml to GitHub — it is already in .gitignore.
#
# On Streamlit Cloud, paste these keys in:
#   App Settings → Secrets (as TOML)

GROQ_API_KEY = "your_groq_api_key_here"
OPENWEATHERMAP_API_KEY = "your_openweathermap_api_key_here"
GPLACES_API_KEY = "your_google_places_api_key_here"
TAVILY_API_KEY = "your_tavily_api_key_here"
EXCHANGE_RATE_API_KEY = "your_exchangerate_api_key_here"
